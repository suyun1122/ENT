# Large directories - MUST exclude
cv_model/venv/
cv_model/training_scripts/surgical_tool_training_runs/
cv_model/runs/
cv_model/temp/
cv_model/*.pt
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.vercel/

# Python virtual environments
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# Git
.git/
.gitignore

# Environment files
.env*
!.env.example

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Video and large files
*.mp4
*.avi
*.mov
*.mkv

# Model weights (except backend/best.pt)
*.pt
!backend/best.pt

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Test and build artifacts
coverage/
runs/
temp/
tmp/
